rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'massab1339@gmail.com';
    }

    // Public Collections (Allow everyone to view products/banners/categories)
    match /categories/{docId} { 
      allow read: if true;
      allow write: if isAdmin();
    }
    match /products/{docId} { 
      allow read: if true;
      allow write: if isAdmin();
    }
    match /banners/{docId} { 
      allow read: if true;
      allow write: if isAdmin();
    }
    match /collections/{docId} { 
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Explicitly allow read for settings/store
    match /settings/store { 
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{docId} { 
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Reviews: Public read, authenticated create
    match /reviews/{docId} { 
      allow read: if true; 
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    
    // Support for potential sub-collections or recursive paths
    match /categories/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /products/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /banners/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /collections/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /settings/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }
    match /reviews/{allPaths=**} { allow read: if true; allow write: if isAdmin(); }

    // Private User Data (Only the logged-in user or Admin can access)
    match /users/{userId} { allow read: if isOwner(userId) || isAdmin(); allow write: if isOwner(userId) || isAdmin(); }
    match /cart/{userId} { allow read, write: if isOwner(userId) || isAdmin(); }
    match /wishlist/{userId} { allow read, write: if isOwner(userId) || isAdmin(); }
    match /addresses/{addressId} { 
      allow read, write: if isSignedIn() && (isAdmin() || resource == null || resource.data.userId == request.auth.uid); 
    }

    // Orders (Owner can create/view, Admin can manage)
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if (resource == null) || (resource.data.type == 'global') || (isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin()));
      allow write: if isAdmin();
    }
  }
}
