{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["customer", "admin", "manager", "super_admin"] },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Category": {
      "title": "Category",
      "description": "Product categories",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "image": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["name"]
    },
    "Product": {
      "title": "Product",
      "description": "Product details",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "categoryId": { "type": "string" },
        "brand": { "type": "string" },
        "price": { "type": "number" },
        "salePrice": { "type": "number" },
        "discount": { "type": "number" },
        "stock": { "type": "number" },
        "soldCount": { "type": "number" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "featured": { "type": "boolean" },
        "bestSeller": { "type": "boolean" },
        "newArrival": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive"] },
        "images": { "type": "array" },
        "sizes": { "type": "array" },
        "colors": { "type": "array" },
        "tags": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "price", "status"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "orderId": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "subtotal": { "type": "number" },
        "shippingFee": { "type": "number" },
        "discount": { "type": "number" },
        "total": { "type": "number" },
        "orderStatus": { "type": "string", "enum": ["pending", "confirmed", "processing", "shipped", "delivered", "cancelled", "returned"] },
        "paymentMethod": { "type": "string" },
        "paymentStatus": { "type": "string" },
        "shippingAddress": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total"]
    },
    "Cart": {
      "title": "Cart",
      "description": "User shopping cart",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" }
      },
      "required": ["userId"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "User wishlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "products": { "type": "array" }
      },
      "required": ["userId"]
    },
    "Review": {
      "title": "Review",
      "description": "Product reviews",
      "type": "object",
      "properties": {
        "reviewId": { "type": "string" },
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["productId", "userId", "rating"]
    },
    "Banner": {
      "title": "Banner",
      "description": "Marketing banners",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "image": { "type": "string" },
        "link": { "type": "string" },
        "type": { "type": "string" },
        "status": { "type": "string" }
      }
    },
    "Collection": {
      "title": "Collection",
      "description": "Featured collections",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "image": { "type": "string" }
      }
    },
    "Coupon": {
      "title": "Coupon",
      "description": "Discount coupons",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "discount": { "type": "number" },
        "type": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      }
    },
    "Notification": {
      "title": "Notification",
      "description": "System notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Address": {
      "title": "Address",
      "description": "User addresses",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "street": { "type": "string" },
        "city": { "type": "string" },
        "zip": { "type": "string" },
        "isDefault": { "type": "boolean" }
      }
    },
    "Settings": {
      "title": "Settings",
      "description": "Store settings",
      "type": "object",
      "properties": {
        "storeName": { "type": "string" },
        "currency": { "type": "string" },
        "shippingFee": { "type": "number" },
        "taxPercentage": { "type": "number" }
      }
    }
  },
  "firestore": {
    "users": { "schema": "User", "description": "User profiles" },
    "categories": { "schema": "Category", "description": "Product categories" },
    "products": { "schema": "Product", "description": "Product catalog" },
    "orders": { "schema": "Order", "description": "Customer orders" },
    "cart": { "schema": "Cart", "description": "User carts" },
    "wishlist": { "schema": "Wishlist", "description": "User wishlist" },
    "reviews": { "schema": "Review", "description": "Product reviews" },
    "banners": { "schema": "Banner", "description": "Home banners" },
    "collections": { "schema": "Collection", "description": "Featured collections" },
    "coupons": { "schema": "Coupon", "description": "Discount coupons" },
    "notifications": { "schema": "Notification", "description": "App notifications" },
    "addresses": { "schema": "Address", "description": "User addresses" },
    "settings": { "schema": "Settings", "description": "Store settings" }
  }
}
